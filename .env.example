# FinMind API token — get one at https://finmindtrade.com/
# Free tier can access TaiwanStockPrice (OHLCV). Paid plan required for:
#   - TaiwanStockBrokerTradingStatement (分點明細, needed for spike_validate.py)
#   - TaiwanStockPriceAdj (dividend-adjusted OHLCV, auto-fallback to free TaiwanStockPrice)
FINMIND_API_KEY=your_finmind_jwt_token_here
FINMIND_TOKEN=your_finmind_jwt_token_here   # same value, both accepted

# PostgreSQL — only needed for integration tests and Phase 1+
# Local setup: brew install postgresql@17 && createdb taiwan_stock
DATABASE_URL=postgresql://user:password@localhost:5432/taiwan_stock

# LLM Reasoning — pick ONE provider (optional; skipped if none set)
# Auto-detect order: ANTHROPIC_API_KEY → OPENAI_API_KEY → GEMINI_API_KEY
# Or force a specific provider:
# LLM_PROVIDER=claude    # claude | openai | gemini
# LLM_MODEL=gpt-4o-mini  # optional model override (default per provider below)
#
# Provider defaults:  claude=claude-sonnet-4-6  openai=gpt-4o  gemini=gemini-2.5-flash
# Note: gemini-2.5-pro is a thinking model — set LLM_MODEL=gemini-2.5-pro + ensure max_tokens>=1500
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...

# Phase 3b FastAPI auth key — optional, skip = dev mode (no auth enforced)
# API_KEY=your_api_key_here
